        {
          "name": "Update Recipe",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Nasi Goreng Spesial - Edisi Revisi",
                  "type": "text",
                  "uuid": "cdca527e-beb3-4650-beed-c46a4d148b55"
                },
                {
                  "key": "description",
                  "value": "Versi yang diperbarui dengan tambahan udang dan pete untuk cita rasa yang lebih kuat.",
                  "type": "text",
                  "uuid": "09b6ba31-f294-4bda-9d50-4b55f9004a72"
                },
                {
                  "key": "ingredients",
                  "value": "[\"2 piring nasi putih dingin\",\"2 butir telur ayam\",\"100 gram udang kupas\",\"5 buah pete (belah dua)\",\"3 siung bawang putih (cincang)\",\"4 siung bawang merah (iris tipis)\",\"2 sdm kecap manis\",\"1 sdm saus tiram\",\"1 sdt garam\",\"1/2 sdt merica bubuk\",\"2 sdm minyak goreng\"]",
                  "type": "text",
                  "uuid": "c38550e1-f252-4563-8e35-0a1f34c765f5"
                },
                {
                  "key": "instructions",
                  "value": "[\"Panaskan minyak, tumis bawang merah dan putih hingga harum.\",\"Masukkan udang dan pete, masak hingga udang berubah warna.\",\"Tambahkan telur, orak-arik sebentar.\",\"Masukkan nasi, kecap manis, saus tiram, garam, dan merica.\",\"Aduk rata selama 5 menit hingga semua bahan tercampur.\",\"Sajikan hangat dengan pelengkap sesuai selera.\"]",
                  "type": "text",
                  "uuid": "4f8100a0-7091-4444-82aa-fef87861e013"
                },
                {
                  "key": "categoryId",
                  "value": "1",
