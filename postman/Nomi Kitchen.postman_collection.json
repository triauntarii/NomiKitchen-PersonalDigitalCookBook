    {
      "name": "Recipe",
      "item": [
        {
          "name": "Create Recipe",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Nasi Goreng Spesial",
                  "type": "text",
                  "uuid": "c8307b73-4f87-4f65-bc93-0751e2795e20"
                },
                {
                  "key": "description",
                  "value": "Nasi goreng rumahan dengan cita rasa yang kaya, dimasak dengan bumbu rempah pilihan dan telur mata sapi di atasnya.",
                  "type": "text",
                  "uuid": "ac8c7390-4659-4b16-84b2-61629ecca31f"
                },
                {
                  "key": "ingredients",
                  "value": "[\"2 piring nasi putih dingin\",\"2 butir telur ayam\",\"3 siung bawang putih (cincang)\",\"4 siung bawang merah (iris tipis)\",\"2 sdm kecap manis\",\"1 sdm saus tiram\",\"1 sdt garam\",\"1/2 sdt merica bubuk\",\"2 sdm minyak goreng\",\"Daun bawang secukupnya\"]",
                  "type": "text",
                  "uuid": "df51e745-d8f9-4afb-ad56-12c4622f979a"
                },
                {
                  "key": "instructions",
                  "value": "[\"Panaskan minyak goreng di wajan dengan api sedang.\",\"Tumis bawang merah dan bawang putih hingga harum dan kecoklatan.\",\"Masukkan telur, orak-arik hingga setengah matang.\",\"Masukkan nasi putih, aduk rata dengan bumbu.\",\"Tambahkan kecap manis, saus tiram, garam, dan merica. Aduk rata.\",\"Masak selama 3-5 menit sambil terus diaduk hingga nasi tercampur sempurna.\",\"Angkat dan sajikan dengan taburan daun bawang dan kerupuk.\"]",
                  "type": "text",
                  "uuid": "1ce4a84e-6144-4f05-877e-cf06a6bde81b"
                },
                {
                  "key": "categoryId",
                  "value": "1",
                  "type": "text",
                  "uuid": "b32061aa-478b-484e-a22a-36c8e947a49c"
                },
                {
                  "key": "photos",
                  "type": "file",
                  "uuid": "2e8cb6ed-d3aa-402a-8819-b6378a3a7268",
                  "src": "/C:/Users/Tria Untari Sasmito/Downloads/nasiGoreng.jpeg"
                }
              ]
            },
