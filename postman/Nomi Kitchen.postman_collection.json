        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Simpan token JWT ke environment variable secara otomatis\r",
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "if (jsonData.token) {\r",
                  "    pm.environment.set(\"token\", jsonData.token);\r",
                  "    console.log(\"✅ Token berhasil disimpan:\", jsonData.token);\r",
                  "} else {\r",
                  "    console.log(\"❎ Token tidak ditemukan dalam response.\");\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
